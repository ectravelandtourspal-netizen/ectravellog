# ─────────────────────────────────────────────
# Trip Monitoring System — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

PORT=5000

# Google Apps Script — deploy as Web App and paste the URL here
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzFYs8JUQSX_qj_WkAjbFHn6QyAaTbDwE-MSkaRhqEuC7RDiVsQ2BgkWeIaJyA4dHZX/exec

# Cloudinary — https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Facebook Messenger — Meta for Developers
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_RECIPIENT_ID=your_recipient_psid_or_page_id
